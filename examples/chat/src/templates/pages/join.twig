{% extends "base.twig" %}
{% block title %}Join Chat{% endblock %}
{% block content %}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Join the Chat</h3>
                {% if error %}<div class="alert alert-danger">{{ error }}</div>{% endif %}
                <form method="POST" action="/join">
                    {{ form_token() }}
                    <div class="mb-3">
                        <label class="form-label">Choose a username</label>
                        <input type="text" name="username" class="form-control" placeholder="johndoe" required autofocus>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Enter Chat</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
