{% extends "base.twig" %}
{% block title %}My Tasks{% endblock %}
{% block content %}
<h2>My Tasks</h2>

<form method="POST" action="/tasks" class="card card-body mb-4">
    {{ form_token() }}
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Title</label>
            <input type="text" name="title" class="form-control" placeholder="Buy groceries" required>
        </div>
        <div class="col-md-3">
            <label class="form-label">Description</label>
            <input type="text" name="description" class="form-control" placeholder="Milk, eggs, bread">
        </div>
        <div class="col-md-3">
            <label class="form-label">Due date</label>
            <input type="date" name="due_date" class="form-control">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Add Task</button>
        </div>
    </div>
</form>

<table class="table">
    <thead>
        <tr><th>Title</th><th>Description</th><th>Due</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
    {% for task in tasks %}
        <tr>
            <td>{{ task.title }}</td>
            <td>{{ task.description|default('') }}</td>
            <td>{{ task.due_date|default('—') }}</td>
            <td>
                {% if task.status == 'completed' %}
                <span class="badge bg-success">Done</span>
                {% else %}
                <span class="badge bg-warning">Pending</span>
                {% endif %}
            </td>
            <td>
                {% if task.status != 'completed' %}
                <form method="POST" action="/tasks/{{ task.id }}/complete" style="display:inline">
                    {{ form_token() }}
                    <button type="submit" class="btn btn-sm btn-success">Complete</button>
                </form>
                {% endif %}
                <form method="POST" action="/tasks/{{ task.id }}/delete" style="display:inline">
                    {{ form_token() }}
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="5" class="text-center text-muted">No tasks yet. Add one above!</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
