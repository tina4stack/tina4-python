{% extends "base.twig" %}
{% block title %}Dashboard — Job Queue{% endblock %}
{% block content %}
<h2>Job Queue Dashboard</h2>

<div class="mb-4">
    <h5>Enqueue a Job</h5>
    <div class="btn-group">
        <button class="btn btn-primary" onclick="enqueue('fetch-weather', {city:'London'})">Fetch Weather</button>
        <button class="btn btn-info" onclick="enqueue('send-notification', {to:'alice@example.com'})">Send Notification</button>
        <button class="btn btn-warning" onclick="enqueue('generate-report', {})">Generate Report</button>
    </div>
    <span id="status" class="ms-3 text-muted"></span>
</div>

<table class="table table-striped" id="jobsTable">
    <thead>
        <tr><th>ID</th><th>Type</th><th>Status</th><th>Result</th><th>Created</th></tr>
    </thead>
    <tbody>
    {% for job in jobs %}
        <tr>
            <td>{{ job.id }}</td>
            <td>{{ job.job_type }}</td>
            <td>
                {% if job.status == 'completed' %}<span class="badge bg-success">{{ job.status }}</span>
                {% elif job.status == 'processing' %}<span class="badge bg-primary">{{ job.status }}</span>
                {% elif job.status == 'failed' %}<span class="badge bg-danger">{{ job.status }}</span>
                {% else %}<span class="badge bg-secondary">{{ job.status }}</span>
                {% endif %}
            </td>
            <td>{{ job.result|default('—') }}</td>
            <td>{{ job.created_at }}</td>
        </tr>
    {% else %}
        <tr><td colspan="5" class="text-center text-muted">No jobs yet. Click a button above!</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}

{% block javascripts %}
<script>
function enqueue(type, data) {
    document.getElementById("status").textContent = "Queuing...";
    sendRequest("/api/jobs/" + type, data, "POST", function(result) {
        document.getElementById("status").textContent = "Queued job #" + result.job_id;
        setTimeout(function() { location.reload(); }, 1000);
    });
}
// Auto-refresh every 3 seconds
setInterval(function() { location.reload(); }, 5000);
</script>
{% endblock %}
