{% extends "base.twig" %}
{% block title %}Home — Tina4 Blog{% endblock %}
{% block content %}
<h1>Latest Posts</h1>
{% for post in posts %}
<div class="card mb-3">
    <div class="card-body">
        <h3><a href="/post/{{ post.slug }}">{{ post.title }}</a></h3>
        <p class="text-muted">By {{ post.author }} — {{ post.created_at }}</p>
        <p>{{ post.content[:200] }}{% if post.content|length > 200 %}...{% endif %}</p>
        <a href="/post/{{ post.slug }}" class="btn btn-primary btn-sm">Read more</a>
    </div>
</div>
{% else %}
<p>No posts yet. The seeder will populate data on first run.</p>
{% endfor %}
{% endblock %}
