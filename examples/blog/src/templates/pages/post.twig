{% extends "base.twig" %}
{% block title %}{{ post.title }} — Tina4 Blog{% endblock %}
{% block content %}
<article>
    <h1>{{ post.title }}</h1>
    <p class="text-muted">By {{ post.author }} — {{ post.created_at }}</p>
    <div class="mb-4">{{ post.content }}</div>
</article>

<hr>
<h3>Comments ({{ comments|length }})</h3>

{% for comment in comments %}
<div class="card mb-2">
    <div class="card-body">
        <strong>{{ comment.name }}</strong>
        <span class="text-muted">— {{ comment.created_at }}</span>
        <p class="mb-0 mt-1">{{ comment.body }}</p>
    </div>
</div>
{% else %}
<p class="text-muted">No comments yet. Be the first!</p>
{% endfor %}

<h4 class="mt-4">Leave a comment</h4>
<form method="POST" action="/post/{{ post.id }}/comment">
    {{ form_token() }}
    <div class="mb-3">
        <input type="text" name="name" class="form-control" placeholder="Your name" required>
    </div>
    <div class="mb-3">
        <input type="email" name="email" class="form-control" placeholder="you@example.com">
    </div>
    <div class="mb-3">
        <textarea name="body" class="form-control" rows="3" placeholder="Write your comment..." required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Post Comment</button>
</form>
{% endblock %}
