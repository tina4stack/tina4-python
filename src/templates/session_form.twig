{% extends "base.twig" %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Session Test — Form Post</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">Fill in the form below. On submit it will POST the data, save it to the session, then redirect to a page that reads it back.</p>
                    <form method="post" action="/session-form">
                        {{ "sessionForm" | form_token }}
                        <div class="mb-3">
                            <label for="name" class="form-label">Name</label>
                            <input type="text" name="name" id="name" class="form-control" placeholder="John Doe" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" name="email" id="email" class="form-control" placeholder="john@example.com" required>
                        </div>
                        <div class="mb-3">
                            <label for="message" class="form-label">Message</label>
                            <textarea name="message" id="message" class="form-control" rows="3" placeholder="Type something to store in the session..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Save to Session &amp; Redirect</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
