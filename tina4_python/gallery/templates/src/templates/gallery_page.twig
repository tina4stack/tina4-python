<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/tina4.min.css">
</head>
<body class="bg-dark text-light">
    <div class="container mt-5">
        <h1 class="mb-4">{{ title }}</h1>
        <p class="text-muted mb-4">This page was rendered using the <code>@template</code> decorator with tina4css styling.</p>

        <div class="row">
            {% for item in items %}
            <div class="col-md-4 mb-3">
                <div class="card bg-secondary text-light">
                    <div class="card-body">
                        <h5 class="card-title">{{ item.name }}</h5>
                        <p class="card-text text-muted">{{ item.description }}</p>
                        <span class="badge bg-primary">{{ item.badge }}</span>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <div class="card bg-secondary mt-4">
            <div class="card-body">
                <h5 class="card-title">How this works</h5>
                <pre class="bg-dark text-success p-3 rounded"><code>@get("/gallery/page")
@template("gallery_page.twig")
async def gallery_page(request, response):
    return {"title": "Gallery Demo Page", "items": [...]}</code></pre>
                <p class="text-muted mt-2">The <code>@template</code> decorator renders the dict return value through this Twig template. Styled with tina4css — no external CDN needed.</p>
            </div>
        </div>
    </div>
</body>
</html>
