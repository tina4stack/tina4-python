msgid "Debug: {message}"
msgstr "调试：{message}"

msgid "Warning: {message}"
msgstr "警告：{message}"

msgid "Error: {message}"
msgstr "错误：{message}"

msgid "Info: {message}"
msgstr "信息：{message}"

msgid "Matching: {matching}"
msgstr "匹配：{matching}"

msgid "Variables: {variables}"
msgstr "变量：{variables}"

msgid "Root Path {root_path} {url}"
msgstr "根路径 {root_path} {url}"

msgid "Attempting to serve static file: {static_file}"
msgstr "尝试提供静态文件：{static_file}"

msgid "Attempting to serve CSS file: {css_file}"
msgstr "尝试提供CSS文件：{css_file}"

msgid "Attempting to serve image file: {image_file}"
msgstr "尝试提供图片文件：{image_file}"

msgid "403 - Forbidden"
msgstr "403 - 禁止访问"

