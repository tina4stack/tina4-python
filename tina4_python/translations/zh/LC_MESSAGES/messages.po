msgstr "路径参数 '{param_name}' 类型无效：期望 {expected}，得到 '{got}'"

msgid "Missing required parameter: {param_name}"
msgstr "缺少必需参数：{param_name}"

msgid "Assuming root path: {root_path}, library path: {library_path}"
msgstr "假定根路径：{root_path}，库路径：{library_path}"

msgid "Load all things"
msgstr "加载所有内容"

msgid "Server started http://{host_name}:{port}"
msgstr "服务器已启动 http://{host_name}:{port}"

msgid "Server stopped."
msgstr "服务器已停止。"

msgid "Starting webserver on {port}"
msgstr "正在端口 {port} 上启动Web服务器"

msgid "Entry point name ... {name}"
msgstr "入口点名称 ... {name}"

