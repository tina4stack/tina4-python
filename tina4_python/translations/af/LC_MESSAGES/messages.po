msgid "Debug: {message}"
msgstr "Ontfout: {message}"

msgid "Warning: {message}"
msgstr "Waarskuwing: {message}"

msgid "Error: {message}"
msgstr "Fout: {message}"

msgid "Info: {message}"
msgstr "Inligting: {message}"

msgid "Matching: {matching}"
msgstr "Passing: {matching}"

msgid "Variables: {variables}"
msgstr "Veranderlikes: {variables}"

msgid "Root Path {root_path} {url}"
msgstr "Wortelpad {root_path} {url}"

msgid "Attempting to serve static file: {static_file}"
msgstr "Probeer om statiese lêer te bedien: {static_file}"

msgid "Attempting to serve CSS file: {css_file}"
msgstr "Probeer om CSS-lêer te bedien: {css_file}"

msgid "Attempting to serve image file: {image_file}"
msgstr "Probeer om prentlêer te bedien: {image_file}"

msgid "403 - Forbidden"
msgstr "403 - Verbode"

msgid "Invalid type for path param '{param_name}': expected {expected}, got '{got}'"
msgstr "Ongeldige tipe vir padparameter '{param_name}': verwag {expected}, gekry '{got}'"

msgid "Missing required parameter: {param_name}"
msgstr "Verpligte parameter ontbreek: {param_name}"

msgid "Assuming root path: {root_path}, library path: {library_path}"
msgstr "Aangenome wortelpad: {root_path}, biblioteekpad: {library_path}"

msgid "Load all things"
msgstr "Laai alles"

msgid "Server started http://{host_name}:{port}"
msgstr "Bediener begin http://{host_name}:{port}"

msgid "Server stopped."
msgstr "Bediener gestop."

msgid "Starting webserver on {port}"
msgstr "Begin webbediener op poort {port}"

msgid "Entry point name ... {name}"
msgstr "Ingangspuntnaam ... {name}"

msgid "Tina4 Python server running on http://{host_name}:{port}"
msgstr "Tina4 Python-bediener loop op http://{host_name}:{port}"

msgid "500 - Internal Server Error"
msgstr "500 - Interne bedienerfout"

msgid "Redirecting..."
msgstr "Herleiding..."

msgid "404 - File Not Found"
msgstr "404 - Lêer nie gevind nie"

msgid "Error reading file: {error}"
msgstr "Fout met lees van lêer: {error}"

msgid "Cannot decode object of type {type}"
msgstr "Kan nie objek van tipe {type} dekodeer nie"

msgid "{name} Record added"
msgstr "{name} Rekord bygevoeg"

msgid "{name} Record updated"
msgstr "{name} Rekord opgedateer"

msgid "{name} Record deleted"
msgstr "{name} Rekord verwyder"

msgid "Error rendering CRUD: {error}"
msgstr "Fout met CRUD-weergawe: {error}"

msgid "Database connection string is missing, try declaring DATABASE_PATH in the .env file."
msgstr "Databasisverbindingstring ontbreek, probeer DATABASE_PATH in die .env-lêer verklaar."

msgid "Could not load database driver for {driver}"
msgstr "Kon nie databasisdrywer vir {driver} laai nie"

msgid "Your python is missing the sqlite3 module, please reinstall or update"
msgstr "Jou Python ontbreek die sqlite3-module, installeer asseblief weer of dateer op"

msgid "Your python is missing the mysql module, please install with {install_cmd}"
msgstr "Jou Python ontbreek die mysql-module, installeer asseblief met {install_cmd}"

msgid "Your python is missing the postgres module, please install with {install_cmd}"
msgstr "Jou Python ontbreek die postgres-module, installeer asseblief met {install_cmd}"

msgid "Your python is missing the firebird module, please install with {install_cmd}"
msgstr "Jou Python ontbreek die firebird-module, installeer asseblief met {install_cmd}"

msgid "Your python is missing the mssql module, please install with {install_cmd}"
msgstr "Jou Python ontbreek die mssql-module, installeer asseblief met {install_cmd}"

msgid "Please implement {driver} in Database.py and make a pull request!"
msgstr "Implementeer asseblief {driver} in Database.py en maak 'n pull request!"

msgid "No SECRET env var set - using default secret. Set SECRET in your .env for production."
msgstr "Geen SECRET-omgewingsveranderlike gestel nie - gebruik verstekgeheim. Stel SECRET in jou .env vir produksie."

msgid "Error creating Websocket, perhaps you need to install simple_websocket ?"
msgstr "Fout met die skep van Websocket, miskien moet jy simple_websocket installeer?"

msgid "Could not establish a socket connection: {error}"
msgstr "Kon nie 'n socket-verbinding bewerkstellig nie: {error}"

msgid "Migration: Found {path}"
msgstr "Migrasie: Gevind {path}"

msgid "Migration: Checking file {file}"
msgstr "Migrasie: Kontroleer lêer {file}"

msgid "Migration: Running migration for {file}"
msgstr "Migrasie: Voer migrasie uit vir {file}"

msgid "PASSED running migration for {file}"
msgstr "GESLAAG migrasie vir {file}"

msgid "FAILED running migration for {file}"
msgstr "MISLUK migrasie vir {file}"

msgid "Migration: Failed to run {file}"
msgstr "Migrasie: Kon nie {file} uitvoer nie"

msgid "Error: tina4_python not installed. Run: pip install tina4-python"
msgstr "Fout: tina4_python is nie geïnstalleer nie. Voer uit: pip install tina4-python"

msgid "Overwriting existing 'app.py' in {path}"
msgstr "Oorskryf bestaande 'app.py' in {path}"

msgid "Creating project in {path}"
msgstr "Skep projek in {path}"

msgid "Project ready!"
msgstr "Projek gereed!"

msgid "Next steps:"
msgstr "Volgende stappe:"

msgid "You are already in the project folder. Run:"
msgstr "Jy is reeds in die projekgids. Voer uit:"

msgid "Dockerfile already exists – skipping creation"
msgstr "Dockerfile bestaan reeds – skepping oorgeslaan"

msgid "Dockerfile created (multi-stage + uv)"
msgstr "Dockerfile geskep (multi-stadium + uv)"

msgid "CLAUDE.md already exists – skipping creation"
msgstr "CLAUDE.md bestaan reeds – skepping oorgeslaan"

msgid "CLAUDE.md created (AI assistant guidelines)"
msgstr "CLAUDE.md geskep (KI-assistent riglyne)"

msgid "Warning: CLAUDE.md template not found in package"
msgstr "Waarskuwing: CLAUDE.md-sjabloon nie in pakket gevind nie"

msgid "Starting Tina4 server on http://localhost:{port}"
msgstr "Begin Tina4-bediener op http://localhost:{port}"

msgid "Error: Migration description cannot be empty"
msgstr "Fout: Migrasiebeskrywing kan nie leeg wees nie"

msgid "Example: tina4python migrate:create create users table"
msgstr "Voorbeeld: tina4python migrate:create create users table"

msgid "Migration created: {filepath}"
msgstr "Migrasie geskep: {filepath}"

msgid "Trying to load dba from: {candidate}"
msgstr "Probeer om dba te laai vanaf: {candidate}"

msgid "Failed to execute {candidate}: {error}"
msgstr "Kon nie {candidate} uitvoer nie: {error}"

msgid "Found dba in {candidate}"
msgstr "dba gevind in {candidate}"

msgid "No dba found in {candidate}"
msgstr "Geen dba gevind in {candidate} nie"

msgid "Could not find a 'dba' instance in any of the following files:"
msgstr "Kon nie 'n 'dba'-instansie in enige van die volgende lêers vind nie:"

msgid "{file} (exists but no dba)"
msgstr "{file} (bestaan maar geen dba)"

msgid "{file} (not found)"
msgstr "{file} (nie gevind nie)"

msgid "Make sure you have something like:"
msgstr "Maak seker jy het iets soos:"

msgid "Using database: {connection}"
msgstr "Gebruik databasis: {connection}"

msgid "Running migrations..."
msgstr "Voer migrasies uit..."

msgid "All migrations completed successfully!"
msgstr "Alle migrasies suksesvol voltooi!"

msgid "Migration error: {error}"
msgstr "Migrasiefout: {error}"
