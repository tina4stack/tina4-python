msgstr "Falta la cadena de conexión a la base de datos, intente declarar DATABASE_PATH en el archivo .env."

msgid "Could not load database driver for {driver}"
msgstr "No se pudo cargar el controlador de base de datos para {driver}"

msgid "Your python is missing the sqlite3 module, please reinstall or update"
msgstr "Su Python no tiene el módulo sqlite3, por favor reinstale o actualice"

msgid "Your python is missing the mysql module, please install with {install_cmd}"
msgstr "Su Python no tiene el módulo mysql, por favor instale con {install_cmd}"

msgid "Your python is missing the postgres module, please install with {install_cmd}"
msgstr "Su Python no tiene el módulo postgres, por favor instale con {install_cmd}"

msgid "Your python is missing the firebird module, please install with {install_cmd}"
msgstr "Su Python no tiene el módulo firebird, por favor instale con {install_cmd}"

msgid "Your python is missing the mssql module, please install with {install_cmd}"
msgstr "Su Python no tiene el módulo mssql, por favor instale con {install_cmd}"

msgid "Please implement {driver} in Database.py and make a pull request!"
msgstr "¡Por favor implemente {driver} en Database.py y haga un pull request!"

msgid "No SECRET env var set - using default secret. Set SECRET in your .env for production."
msgstr "Variable SECRET no configurada - usando secreto predeterminado. Configure SECRET en .env para producción."

msgid "Error creating Websocket, perhaps you need to install simple_websocket ?"
msgstr "Error al crear Websocket, ¿quizás necesita instalar simple_websocket?"

msgid "Could not establish a socket connection: {error}"
msgstr "No se pudo establecer una conexión socket: {error}"

