msgstr "Asegúrese de tener algo como:"

msgid "Using database: {connection}"
msgstr "Usando base de datos: {connection}"

msgid "Running migrations..."
msgstr "Ejecutando migraciones..."

msgid "All migrations completed successfully!"
msgstr "¡Todas las migraciones se completaron exitosamente!"

msgid "Migration error: {error}"
msgstr "Error de migración: {error}"
