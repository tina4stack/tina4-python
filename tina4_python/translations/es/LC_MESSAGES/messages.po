msgstr "EXITOSA ejecución de migración para {file}"

msgid "FAILED running migration for {file}"
msgstr "FALLIDA ejecución de migración para {file}"

msgid "Migration: Failed to run {file}"
msgstr "Migración: Error al ejecutar {file}"

