msgid "Debug: {message}"
msgstr "Débogage : {message}"

msgid "Warning: {message}"
msgstr "Avertissement : {message}"

msgid "Error: {message}"
msgstr "Erreur : {message}"

msgid "Info: {message}"
msgstr "Info : {message}"

msgid "Matching: {matching}"
msgstr "Correspondance : {matching}"

msgid "Variables: {variables}"
msgstr "Variables : {variables}"

msgid "Root Path {root_path} {url}"
msgstr "Chemin racine {root_path} {url}"

msgid "Attempting to serve static file: {static_file}"
msgstr "Tentative de service du fichier statique : {static_file}"

msgid "Attempting to serve CSS file: {css_file}"
msgstr "Tentative de service du fichier CSS : {css_file}"

msgid "Attempting to serve image file: {image_file}"
msgstr "Tentative de service du fichier image : {image_file}"

msgid "403 - Forbidden"
msgstr "403 - Accès interdit"

msgid "Invalid type for path param '{param_name}': expected {expected}, got '{got}'"
msgstr "Type invalide pour le paramètre '{param_name}' : attendu {expected}, obtenu '{got}'"

msgid "Missing required parameter: {param_name}"
msgstr "Paramètre obligatoire manquant : {param_name}"

msgid "Assuming root path: {root_path}, library path: {library_path}"
msgstr "Chemin racine supposé : {root_path}, chemin bibliothèque : {library_path}"

msgid "Load all things"
msgstr "Charger tous les éléments"

msgid "Server started http://{host_name}:{port}"
msgstr "Serveur démarré http://{host_name}:{port}"

msgid "Server stopped."
msgstr "Serveur arrêté."

msgid "Starting webserver on {port}"
msgstr "Démarrage du serveur web sur le port {port}"

msgid "Entry point name ... {name}"
msgstr "Nom du point d'entrée ... {name}"

msgid "Tina4 Python server running on http://{host_name}:{port}"
msgstr "Serveur Tina4 Python en cours d'exécution sur http://{host_name}:{port}"

msgid "500 - Internal Server Error"
msgstr "500 - Erreur interne du serveur"

msgid "Redirecting..."
msgstr "Redirection en cours..."

msgid "404 - File Not Found"
msgstr "404 - Fichier introuvable"

msgid "Error reading file: {error}"
msgstr "Erreur lors de la lecture du fichier : {error}"

msgid "Cannot decode object of type {type}"
msgstr "Impossible de décoder l'objet de type {type}"

msgid "{name} Record added"
msgstr "{name} Enregistrement ajouté"

msgid "{name} Record updated"
msgstr "{name} Enregistrement mis à jour"

msgid "{name} Record deleted"
msgstr "{name} Enregistrement supprimé"

msgid "Error rendering CRUD: {error}"
msgstr "Erreur lors du rendu CRUD : {error}"

msgid "Database connection string is missing, try declaring DATABASE_PATH in the .env file."
msgstr "La chaîne de connexion est manquante, essayez de déclarer DATABASE_PATH dans le fichier .env."

msgid "Could not load database driver for {driver}"
msgstr "Impossible de charger le pilote de base de données pour {driver}"

msgid "Your python is missing the sqlite3 module, please reinstall or update"
msgstr "Le module sqlite3 est manquant, veuillez réinstaller ou mettre à jour Python"

msgid "Your python is missing the mysql module, please install with {install_cmd}"
msgstr "Le module mysql est manquant, veuillez l'installer avec {install_cmd}"

msgid "Your python is missing the postgres module, please install with {install_cmd}"
msgstr "Le module postgres est manquant, veuillez l'installer avec {install_cmd}"

msgid "Your python is missing the firebird module, please install with {install_cmd}"
msgstr "Le module firebird est manquant, veuillez l'installer avec {install_cmd}"

msgid "Your python is missing the mssql module, please install with {install_cmd}"
msgstr "Le module mssql est manquant, veuillez l'installer avec {install_cmd}"

msgid "Please implement {driver} in Database.py and make a pull request!"
msgstr "Veuillez implémenter {driver} dans Database.py et soumettre une pull request !"

msgid "No SECRET env var set - using default secret. Set SECRET in your .env for production."
msgstr "Variable SECRET non définie - utilisation du secret par défaut. Définissez SECRET dans .env pour la production."

msgid "Error creating Websocket, perhaps you need to install simple_websocket ?"
msgstr "Erreur lors de la création du WebSocket, vous devez peut-être installer simple_websocket ?"

msgid "Could not establish a socket connection: {error}"
msgstr "Impossible d'établir une connexion socket : {error}"

msgid "Migration: Found {path}"
msgstr "Migration : Trouvé {path}"

msgid "Migration: Checking file {file}"
msgstr "Migration : Vérification du fichier {file}"

msgid "Migration: Running migration for {file}"
msgstr "Migration : Exécution de la migration pour {file}"

msgid "PASSED running migration for {file}"
msgstr "RÉUSSIE exécution de la migration pour {file}"

msgid "FAILED running migration for {file}"
msgstr "ÉCHOUÉE exécution de la migration pour {file}"

msgid "Migration: Failed to run {file}"
msgstr "Migration : Échec de l'exécution de {file}"

msgid "Error: tina4_python not installed. Run: pip install tina4-python"
msgstr "Erreur : tina4_python n'est pas installé. Exécutez : pip install tina4-python"

msgid "Overwriting existing 'app.py' in {path}"
msgstr "Remplacement du fichier 'app.py' existant dans {path}"

msgid "Creating project in {path}"
msgstr "Création du projet dans {path}"

msgid "Project ready!"
msgstr "Projet prêt !"

msgid "Next steps:"
msgstr "Prochaines étapes :"

msgid "You are already in the project folder. Run:"
msgstr "Vous êtes déjà dans le dossier du projet. Exécutez :"

msgid "Dockerfile already exists – skipping creation"
msgstr "Le Dockerfile existe déjà – création ignorée"

msgid "Dockerfile created (multi-stage + uv)"
msgstr "Dockerfile créé (multi-étape + uv)"

msgid "CLAUDE.md already exists – skipping creation"
msgstr "CLAUDE.md existe déjà – création ignorée"

msgid "CLAUDE.md created (AI assistant guidelines)"
msgstr "CLAUDE.md créé (directives pour l'assistant IA)"

msgid "Warning: CLAUDE.md template not found in package"
msgstr "Avertissement : le modèle CLAUDE.md est introuvable dans le package"

msgid "Starting Tina4 server on http://localhost:{port}"
msgstr "Démarrage du serveur Tina4 sur http://localhost:{port}"

msgid "Error: Migration description cannot be empty"
msgstr "Erreur : la description de la migration ne peut pas être vide"

msgid "Example: tina4 migrate:create create users table"
msgstr "Exemple : tina4 migrate:create create users table"

msgid "Migration created: {filepath}"
msgstr "Migration créée : {filepath}"

msgid "Trying to load dba from: {candidate}"
msgstr "Tentative de chargement de dba depuis : {candidate}"

msgid "Failed to execute {candidate}: {error}"
msgstr "Échec de l'exécution de {candidate} : {error}"

msgid "Found dba in {candidate}"
msgstr "dba trouvé dans {candidate}"

msgid "No dba found in {candidate}"
msgstr "Aucun dba trouvé dans {candidate}"

msgid "Could not find a 'dba' instance in any of the following files:"
msgstr "Impossible de trouver une instance 'dba' dans les fichiers suivants :"

msgid "{file} (exists but no dba)"
msgstr "{file} (existe mais sans dba)"

msgid "{file} (not found)"
msgstr "{file} (introuvable)"

msgid "Make sure you have something like:"
msgstr "Assurez-vous d'avoir quelque chose comme :"

msgid "Using database: {connection}"
msgstr "Utilisation de la base de données : {connection}"

msgid "Running migrations..."
msgstr "Exécution des migrations..."

msgid "All migrations completed successfully!"
msgstr "Toutes les migrations ont été effectuées avec succès !"

msgid "Migration error: {error}"
msgstr "Erreur de migration : {error}"
